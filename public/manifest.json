{
  "manifest_version": 3,
  "name": "Lychee AI",
  "version": "0.1.0",
  "description": "A model-agnostic AI agent in your side panel that can (with your permission) read, control, and research the web with you.",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "storage", "scripting", "tabs", "alarms", "activeTab", "clipboardWrite", "favicon", "offscreen", "notifications"],
  "optional_permissions": ["history", "bookmarks", "topSites", "downloads"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Lychee AI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Toggle the Lychee AI side panel"
    }
  }
}
